{
  "buildCommand": "npx expo export -p web",
  "outputDirectory": "dist/client",
  "cleanUrls": true,
  "functions": {
    "api/index.js": {
      "includeFiles": "dist/server/**"
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/index" },
    { "source": "/(.*)", "destination": "/api/index" }
  ]
}
